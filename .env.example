# ============================================================================
# MoveSmart Rentals — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# All NEXT_PUBLIC_ vars are exposed to the browser (client-side).
# All other vars are server-side only.
# ============================================================================

# ---------------------------------------------------------------------------
# Sanity CMS
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=        # Sanity Dashboard > Project > Settings > API
NEXT_PUBLIC_SANITY_DATASET=production # Usually "production"
SANITY_API_READ_TOKEN=                # Sanity Dashboard > API > Tokens > Add token (Viewer)
SANITY_WEBHOOK_SECRET=                # Random string, must match Sanity webhook config

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://movesmartrentals.com  # Canonical site URL (used for OG tags, sitemaps)

# ---------------------------------------------------------------------------
# Google Tag Manager
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GTM_ID=                   # GTM Dashboard > Container ID (GTM-XXXXXXX)

# ---------------------------------------------------------------------------
# Google Search Console
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GSC_VERIFICATION=         # GSC > Settings > Ownership verification > HTML tag

# ---------------------------------------------------------------------------
# Bing Webmaster Tools
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BING_VERIFICATION=        # Bing Webmaster > Settings > Ownership verification

# ---------------------------------------------------------------------------
# reCAPTCHA v3
# ---------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=       # Google reCAPTCHA admin > Site key
RECAPTCHA_SECRET_KEY=                 # Google reCAPTCHA admin > Secret key

# ---------------------------------------------------------------------------
# Zoho SalesIQ
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SALESIQ_WIDGET_CODE=      # SalesIQ Dashboard > Settings > Widget code
