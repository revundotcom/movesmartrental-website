# ============================================================================
# MoveSmart Rentals — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# NEXT_PUBLIC_* variables are inlined into the client bundle at build time
# and are visible to any browser visitor — never put secrets there.
# Every other variable is server-only (API routes, server components, scripts).
#
# In Vercel, configure each of these under:
#   Project → Settings → Environment Variables
# and choose the appropriate scopes (Production / Preview / Development).
# ============================================================================


# ─── Site ───────────────────────────────────────────────────────────────────
# Canonical production URL (no trailing slash).
# Used for metadataBase, canonical tags, OG URLs, sitemap absolute URLs,
# robots.txt, and all JSON-LD schemas.
NEXT_PUBLIC_SITE_URL=https://movesmartrentals.com


# ─── Analytics ──────────────────────────────────────────────────────────────
# Google Tag Manager container ID — e.g. GTM-XXXXXXX.
# When present, layout.tsx injects <GoogleTagManager/>; unset → no GTM.
NEXT_PUBLIC_GTM_ID=

# GA4 property ID — used by the internal /admin/analytics page.
# Format: 9-digit numeric ID (not the G-XXXX measurement ID).
NEXT_PUBLIC_GA4_PROPERTY_ID=

# Looker Studio dashboard URL — embedded on /admin/analytics.
# Paste the full shareable URL including /reporting/... path.
NEXT_PUBLIC_LOOKER_STUDIO_URL=


# ─── Zoho SalesIQ (live chat) ───────────────────────────────────────────────
# Widget code from SalesIQ → Settings → Brands → Installation → Widget code.
# When present, layout.tsx injects the SalesIQ script; unset → no chat.
NEXT_PUBLIC_SALESIQ_WIDGET_CODE=


# ─── Forms / Anti-spam ──────────────────────────────────────────────────────
# Google reCAPTCHA v3 site key (client-side) — used by the contact form.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google reCAPTCHA v3 secret key (server-only) — used by /api/contact to verify.
# If unset, the API route skips reCAPTCHA verification (dev/staging convenience).
RECAPTCHA_SECRET_KEY=


# ─── Search Engine Verification ─────────────────────────────────────────────
# Google Search Console verification token (the "content" value of the meta tag).
NEXT_PUBLIC_GSC_VERIFICATION=

# Google Search Console property URL — linked from /admin/analytics so the team
# can jump directly to coverage / performance reports.
# Format: https://search.google.com/search-console?resource_id=sc-domain:movesmartrentals.com
NEXT_PUBLIC_GSC_PROPERTY_URL=

# Bing Webmaster Tools verification token (msvalidate.01 meta content).
NEXT_PUBLIC_BING_VERIFICATION=
